---
import "../styles/global.css";
import { profile } from "../data/content";

interface Props {
  title?: string;
  description?: string;
}
const {
  title = `${profile.shortName} — ${profile.role.es}`,
  description = profile.intro.es,
} = Astro.props;

const base = import.meta.env.BASE_URL;
const ogImage = `${base}images/diego-portrait.jpg`;
---

<!doctype html>
<html lang="es" data-lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" href={`${base}favicon.svg`} type="image/svg+xml" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="author" content={profile.name} />
    <meta name="theme-color" content="#07080c" />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta name="twitter:card" content="summary_large_image" />

    <!-- Fuentes -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,400;9..144,500;9..144,600&family=Inter:wght@400;500;600&family=JetBrains+Mono:wght@400;500&display=swap"
      rel="stylesheet"
    />

    <!-- Idioma: fijar antes del primer paint para evitar parpadeo -->
    <script is:inline>
      (function () {
        try {
          var l = localStorage.getItem("lang");
          if (!l) {
            l = (navigator.language || "es").toLowerCase().startsWith("en") ? "en" : "es";
          }
          document.documentElement.setAttribute("data-lang", l);
          document.documentElement.setAttribute("lang", l);
        } catch (e) {}
      })();
    </script>
  </head>
  <body>
    <!-- Aurora de fondo: luces verde · azul · morado -->
    <div class="aurora" aria-hidden="true"></div>

    <!-- Riel de progreso: el recorrido como pipeline de inferencia -->
    <div class="scroll-rail" aria-hidden="true">
      <span class="scroll-rail__label">inference&nbsp;·&nbsp;scroll</span>
      <div class="scroll-rail__fill"></div>
      <div class="scroll-rail__head"></div>
    </div>

    <slot />

    <!-- ── Paleta dinámica: el acento global muta según la sección visible ── -->
    <script is:inline>
      (function () {
        const root = document.documentElement;
        const sections = Array.from(document.querySelectorAll("[data-palette]"));
        if (!sections.length) return;

        function readPalette(el) {
          const s = getComputedStyle(el);
          return {
            glow: s.getPropertyValue("--glow").trim(),
            accent: s.getPropertyValue("--accent").trim(),
            accent2: s.getPropertyValue("--accent-2").trim(),
          };
        }
        function apply(el) {
          const p = readPalette(el);
          root.style.setProperty("--page-glow", p.glow);
          root.style.setProperty("--page-accent", p.accent);
        }

        let current = null;
        const io = new IntersectionObserver(
          (entries) => {
            // Sección con mayor intersección manda
            let best = null;
            for (const e of entries) {
              if (e.isIntersecting && (!best || e.intersectionRatio > best.intersectionRatio)) {
                best = e;
              }
            }
            if (best && best.target !== current) {
              current = best.target;
              apply(current);
            }
          },
          { threshold: [0.25, 0.5, 0.75], rootMargin: "-35% 0px -35% 0px" }
        );
        sections.forEach((s) => io.observe(s));
        apply(sections[0]);
      })();
    </script>

    <!-- ── Reveal al hacer scroll ── -->
    <script is:inline>
      (function () {
        const els = document.querySelectorAll(".reveal");
        if (!("IntersectionObserver" in window) || !els.length) {
          els.forEach((e) => e.classList.add("is-in"));
          return;
        }
        const io = new IntersectionObserver(
          (entries, obs) => {
            entries.forEach((e) => {
              if (e.isIntersecting) {
                e.target.classList.add("is-in");
                obs.unobserve(e.target);
              }
            });
          },
          { threshold: 0.12, rootMargin: "0px 0px -8% 0px" }
        );
        els.forEach((e) => io.observe(e));
      })();
    </script>

    <!-- ── Micro-interacciones: decode, count-up, spotlight, magnético, riel ── -->
    <script is:inline>
      (function () {
        const reduce = window.matchMedia("(prefers-reduced-motion: reduce)").matches;

        /* 1 · Decode de tokens en el titular (efecto LLM generando) */
        function decode(el) {
          const glyphs = "ABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789<>/{}[]=+*";
          const lines = el.innerHTML.split(/<br\s*\/?>/i).map((s) => s);
          const plain = lines.map((l) => l.replace(/&amp;/g, "&"));
          const total = plain.reduce((a, l) => a + l.length, 0);
          let revealed = 0;
          const speed = Math.max(1, Math.round(total / 38));
          function frame() {
            revealed += speed;
            let count = 0;
            const out = plain.map((line) =>
              line
                .split("")
                .map((ch) => {
                  count++;
                  if (ch === " ") return " ";
                  if (count <= revealed) return ch;
                  if (count <= revealed + 8)
                    return `<span class="dec-glitch">${glyphs[(Math.random() * glyphs.length) | 0]}</span>`;
                  return `<span class="dec-hidden">${ch}</span>`;
                })
                .join("")
            );
            el.innerHTML = out.join("<br>");
            if (revealed < total) requestAnimationFrame(frame);
            else el.innerHTML = lines.join("<br>");
          }
          frame();
        }
        function decodeHeadlines(delay) {
          if (reduce) return;
          const lang = document.documentElement.getAttribute("data-lang");
          document.querySelectorAll("[data-decode]").forEach((el) => {
            const visible = el.querySelector(lang === "en" ? "[data-lang-en]" : "[data-lang-es]");
            const target = visible || el;
            if (target.dataset.decoded === lang) return;
            target.dataset.decoded = lang;
            setTimeout(() => decode(target), delay);
          });
        }
        decodeHeadlines(350);
        document.addEventListener("langchange", () => decodeHeadlines(60));

        /* 2 · Count-up de métricas al entrar en viewport */
        function countUp(el) {
          const raw = el.textContent.trim();
          const m = raw.match(/^(\d+)(.*)$/);
          if (!m) return;
          const end = parseInt(m[1], 10);
          const suffix = m[2] || "";
          if (reduce) { el.textContent = raw; return; }
          const dur = 1400;
          const start = performance.now();
          function tick(now) {
            const p = Math.min(1, (now - start) / dur);
            const eased = 1 - Math.pow(1 - p, 3);
            el.textContent = Math.round(end * eased) + suffix;
            if (p < 1) requestAnimationFrame(tick);
            else el.textContent = raw;
          }
          requestAnimationFrame(tick);
        }
        const metrics = document.querySelectorAll(".metric");
        if (metrics.length) {
          const mo = new IntersectionObserver((entries, obs) => {
            entries.forEach((e) => {
              if (e.isIntersecting) { countUp(e.target); obs.unobserve(e.target); }
            });
          }, { threshold: 0.6 });
          metrics.forEach((m) => mo.observe(m));
        }

        /* 3 · Spotlight de cursor: actualiza --mx/--my en la tarjeta */
        document.addEventListener("pointermove", (e) => {
          const card = e.target.closest && e.target.closest(".card");
          if (!card) return;
          const r = card.getBoundingClientRect();
          card.style.setProperty("--mx", (e.clientX - r.left) + "px");
          card.style.setProperty("--my", (e.clientY - r.top) + "px");
        }, { passive: true });

        /* 4 · Botón magnético (CTA primario) */
        if (!reduce && window.matchMedia("(pointer:fine)").matches) {
          document.querySelectorAll(".btn-primary").forEach((btn) => {
            btn.addEventListener("pointermove", (e) => {
              const r = btn.getBoundingClientRect();
              const mx = e.clientX - r.left - r.width / 2;
              const my = e.clientY - r.top - r.height / 2;
              btn.style.transform = `translate(${mx * 0.22}px, ${my * 0.3}px)`;
            });
            btn.addEventListener("pointerleave", () => { btn.style.transform = ""; });
          });
        }

        /* 5 · Riel de progreso de scroll */
        const rail = document.querySelector(".scroll-rail");
        if (rail) {
          let ticking = false;
          function update() {
            ticking = false;
            const h = document.documentElement;
            const max = h.scrollHeight - h.clientHeight;
            const p = max > 0 ? Math.min(1, h.scrollTop / max) : 0;
            rail.style.setProperty("--p", p.toFixed(4));
          }
          window.addEventListener("scroll", () => {
            if (!ticking) { ticking = true; requestAnimationFrame(update); }
          }, { passive: true });
          window.addEventListener("resize", update);
          update();
        }
      })();
    </script>
  </body>
</html>

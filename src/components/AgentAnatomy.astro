---
/* ════════════════════════════════════════════════════════════════════════
   AgentAnatomy — scrollytelling "Anatomía de un agente"
   Sección fijada (sticky): al hacer scroll se ensambla la arquitectura de un
   agente — Núcleo LLM → Herramientas → Memoria → Planeación → Guardrails —
   con una traza de razonamiento en vivo. Es el contenido real de la
   masterclass de SICE; la estructura codifica algo verdadero, no decora.
   Progressive enhancement: si prefers-reduced-motion, se muestra apilado.
   ════════════════════════════════════════════════════════════════════════ */
import T from "./T.astro";

const steps = [
  {
    id: "reason",
    idx: 0,
    no: "01",
    title: { es: "El núcleo razona", en: "The core reasons" },
    body: {
      es: "Un LLM en el centro no es el producto: es el motor de inferencia. La ingeniería empieza cuando lo rodeas de estructura para que razone con criterio, no que improvise.",
      en: "An LLM at the center isn't the product — it's the inference engine. Engineering begins when you surround it with structure so it reasons with judgment instead of improvising.",
    },
    trace: "[core] modelo local listo · contexto 8k tokens",
  },
  {
    id: "tools",
    idx: 1,
    no: "02",
    title: { es: "Herramientas para actuar", en: "Tools to act" },
    body: {
      es: "Un agente sin herramientas solo habla. Le doy manos: búsqueda, ejecución de código, APIs y acceso a sistemas reales, con contratos tipados que validan cada llamada.",
      en: "An agent without tools only talks. I give it hands: search, code execution, APIs and access to real systems — with typed contracts that validate every call.",
    },
    trace: "[tools] registradas → search() · code() · http()",
  },
  {
    id: "memory",
    idx: 2,
    no: "03",
    title: { es: "Memoria que recuerda", en: "Memory that remembers" },
    body: {
      es: "Memoria de corto plazo para la tarea y memoria vectorial de largo plazo para el contexto. SQLite para estado, ChromaDB para recuperar lo relevante cuando importa.",
      en: "Short-term memory for the task and long-term vector memory for context. SQLite for state, ChromaDB to retrieve what's relevant when it matters.",
    },
    trace: "[memory] SQLite 143 items · ChromaDB vectores ok",
  },
  {
    id: "plan",
    idx: 3,
    no: "04",
    title: { es: "Planeación que descompone", en: "Planning that decomposes" },
    body: {
      es: "Aquí vive la inteligencia agéntica: patrones ReAct y Reflection orquestados con LangGraph. El agente descompone el objetivo, decide en cada nodo y se corrige antes de avanzar.",
      en: "This is where agentic intelligence lives: ReAct and Reflection patterns orchestrated with LangGraph. The agent decomposes the goal, decides at each node and corrects itself before moving on.",
    },
    trace: "[planner] ReAct → 3 subtareas · reflexión activa",
  },
  {
    id: "guard",
    idx: 4,
    no: "05",
    title: { es: "Guardrails con criterio", en: "Guardrails with judgment" },
    body: {
      es: "Autonomía calibrada: el agente ejecuta rutinas solo, pero pide aprobación en acciones irreversibles. Privacidad, trazabilidad y validación no son extras — son la ingeniería.",
      en: "Calibrated autonomy: the agent runs routines on its own but asks approval for irreversible actions. Privacy, traceability and validation aren't extras — they are the engineering.",
    },
    trace: "[guard] acción irreversible → requiere aprobación",
  },
];
---

<section id="anatomy" class="anatomy section" data-palette="argos">
  <div class="shell anatomy-head">
    <p class="kicker reveal"><T es="Cómo construyo" en="How I build" /></p>
    <h2 class="section-title reveal" data-delay="1">
      <T es="Anatomía de un agente" en="Anatomy of an agent" />
    </h2>
    <p class="section-lead reveal" data-delay="2">
      <T
        es="No es un chatbot con un prompt. Es un sistema. Desplázate para ensamblarlo, pieza por pieza."
        en="It's not a chatbot with a prompt. It's a system. Scroll to assemble it, piece by piece."
      />
    </p>
  </div>

  <div class="anatomy-scroll" data-steps={steps.length}>
    <div class="anatomy-stage">
      <div class="shell stage-grid">
        <!-- Diagrama ensamblable -->
        <div class="stage-diagram" data-active="0">
          <svg class="diagram-lines" viewBox="0 0 100 100" preserveAspectRatio="none" aria-hidden="true">
            <line class="link" data-link="1" x1="50" y1="50" x2="20" y2="20" />
            <line class="link" data-link="2" x1="50" y1="50" x2="80" y2="20" />
            <line class="link" data-link="3" x1="50" y1="50" x2="20" y2="80" />
            <line class="link" data-link="4" x1="50" y1="50" x2="80" y2="80" />
          </svg>

          <div class="diagram-core node-core is-on">
            <span class="core-ring" aria-hidden="true"></span>
            <span class="core-label font-mono">LLM</span>
            <span class="core-sub font-mono">core</span>
          </div>

          <div class="diagram-node node-sat" data-node="1" style="left:20%;top:20%">
            <span class="node-dot" aria-hidden="true"></span>
            <span class="font-mono">Tools</span>
          </div>
          <div class="diagram-node node-sat" data-node="2" style="left:80%;top:20%">
            <span class="node-dot" aria-hidden="true"></span>
            <span class="font-mono">Memory</span>
          </div>
          <div class="diagram-node node-sat" data-node="3" style="left:20%;top:80%">
            <span class="node-dot" aria-hidden="true"></span>
            <span class="font-mono">Planner</span>
          </div>
          <div class="diagram-node node-sat" data-node="4" style="left:80%;top:80%">
            <span class="node-dot" aria-hidden="true"></span>
            <span class="font-mono">Guardrails</span>
          </div>

          <div class="loop-badge font-mono" aria-hidden="true">
            Perceive · Reason · Plan · Act · Reflect
          </div>
        </div>

        <!-- Copia + traza -->
        <div class="stage-copy">
          <div class="step-track">
            {steps.map((s) => (
              <div class="stage-step" data-step={s.idx}>
                <span class="step-no font-mono">{s.no} / 05</span>
                <h3 class="step-title"><T es={s.title.es} en={s.title.en} /></h3>
                <p class="step-body"><T es={s.body.es} en={s.body.en} /></p>
              </div>
            ))}
          </div>

          <div class="trace nm-recessed" aria-hidden="true">
            <div class="trace-head font-mono">
              <span class="trace-dot"></span> reasoning trace
            </div>
            <div class="trace-log font-mono" data-trace></div>
          </div>

          <div class="step-progress" aria-hidden="true">
            {steps.map((s) => <span class="prog-tick" data-tick={s.idx}></span>)}
          </div>
        </div>
      </div>
    </div>
  </div>

  <script is:inline define:vars={{ traces: steps.map((s) => s.trace) }}>
    (function () {
      const section = document.getElementById("anatomy");
      if (!section) return;
      const scroll = section.querySelector(".anatomy-scroll");
      const diagram = section.querySelector(".stage-diagram");
      const steps = section.querySelectorAll(".stage-step");
      const sats = section.querySelectorAll(".node-sat");
      const links = section.querySelectorAll(".link");
      const ticks = section.querySelectorAll(".prog-tick");
      const traceLog = section.querySelector("[data-trace]");
      const total = steps.length;
      const reduce = window.matchMedia("(prefers-reduced-motion: reduce)").matches;

      let current = -1;

      function setActive(idx) {
        if (idx === current) return;
        current = idx;
        diagram.setAttribute("data-active", String(idx));

        steps.forEach((s) => s.classList.toggle("is-active", +s.dataset.step === idx));
        ticks.forEach((t) => t.classList.toggle("is-on", +t.dataset.tick <= idx));
        // satélites: encendidos los de índice <= idx (idx 0 = solo core)
        sats.forEach((n) => n.classList.toggle("is-on", +n.dataset.node <= idx));
        links.forEach((l) => l.classList.toggle("is-on", +l.dataset.link <= idx));

        // traza acumulada
        if (traceLog) {
          traceLog.innerHTML = "";
          for (let i = 0; i <= idx; i++) {
            const line = document.createElement("div");
            line.className = "trace-line" + (i === idx ? " is-new" : "");
            line.textContent = traces[i];
            traceLog.appendChild(line);
          }
        }
      }

      if (reduce) {
        section.classList.add("reduced");
        steps.forEach((s) => s.classList.add("is-active"));
        sats.forEach((n) => n.classList.add("is-on"));
        links.forEach((l) => l.classList.add("is-on"));
        ticks.forEach((t) => t.classList.add("is-on"));
        if (traceLog) traces.forEach((tx) => {
          const line = document.createElement("div");
          line.className = "trace-line";
          line.textContent = tx;
          traceLog.appendChild(line);
        });
        return;
      }

      let ticking = false;
      function onScroll() {
        if (ticking) return;
        ticking = true;
        requestAnimationFrame(() => {
          ticking = false;
          const rect = scroll.getBoundingClientRect();
          const dist = rect.height - window.innerHeight;
          const passed = Math.min(Math.max(-rect.top, 0), dist);
          const progress = dist > 0 ? passed / dist : 0;
          // mapeo a paso: reparte el rango en N tramos
          const idx = Math.min(total - 1, Math.floor(progress * total * 0.999));
          setActive(idx < 0 ? 0 : idx);
        });
      }

      window.addEventListener("scroll", onScroll, { passive: true });
      window.addEventListener("resize", onScroll);
      setActive(0);
      onScroll();
    })();
  </script>
</section>

<style>
  .anatomy { padding-bottom: 0; }
  .anatomy-head { max-width: 60ch; }

  .anatomy-scroll { position: relative; height: 420vh; }
  .anatomy-stage {
    position: sticky;
    top: 0;
    height: 100vh;
    display: flex;
    align-items: center;
    overflow: hidden;
  }
  .stage-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2.5rem;
    align-items: center;
    width: min(1200px, 92vw);
  }

  /* ── Diagrama ─────────────────────────────────────────────── */
  .stage-diagram {
    position: relative;
    aspect-ratio: 1 / 1;
    width: min(78vw, 360px);
    margin-inline: auto;
  }
  .diagram-lines {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    overflow: visible;
  }
  .link {
    stroke: rgba(var(--page-glow), 0.16);
    stroke-width: 0.5;
    stroke-dasharray: 90;
    stroke-dashoffset: 90;
    transition: stroke-dashoffset 0.7s cubic-bezier(0.16, 1, 0.3, 1), stroke 0.5s ease;
  }
  .link.is-on {
    stroke: rgba(var(--page-glow), 0.55);
    stroke-dashoffset: 0;
  }

  .diagram-core {
    position: absolute;
    left: 50%; top: 50%;
    transform: translate(-50%, -50%);
    width: 86px; height: 86px;
    display: grid; place-content: center; text-align: center;
    border-radius: 50%;
    background: var(--bg);
    box-shadow: var(--nm-shadow-outset);
    border: 1px solid rgba(var(--page-glow), 0.25);
    z-index: 3;
  }
  .core-ring {
    position: absolute; inset: -10px;
    border-radius: 50%;
    border: 1px solid rgba(var(--page-glow), 0.3);
    animation: core-spin 8s linear infinite;
  }
  .core-ring::before {
    content: ""; position: absolute; top: -3px; left: 50%;
    width: 6px; height: 6px; border-radius: 50%;
    background: var(--accent-2);
    box-shadow: 0 0 10px rgba(var(--page-glow), 0.9);
    transform: translateX(-50%);
  }
  @keyframes core-spin { to { transform: rotate(360deg); } }
  .core-label { font-size: 1.1rem; color: var(--accent-2); font-weight: 500; }
  .core-sub { font-size: 0.6rem; color: var(--text-dim); letter-spacing: 0.2em; }

  .diagram-node {
    position: absolute;
    transform: translate(-50%, -50%) scale(0.85);
    display: inline-flex; align-items: center; gap: 0.45rem;
    padding: 0.4rem 0.8rem; border-radius: 99px;
    background: var(--bg-soft);
    border: 1px solid rgba(255, 255, 255, 0.03);
    box-shadow: var(--nm-shadow-inset-sm);
    font-size: 0.72rem; color: var(--text-dim);
    white-space: nowrap;
    opacity: 0.3;
    transition: opacity 0.55s ease, transform 0.55s cubic-bezier(0.16, 1, 0.3, 1), color 0.4s ease, box-shadow 0.4s ease, border-color 0.4s ease;
    z-index: 2;
  }
  .node-dot {
    width: 6px; height: 6px; border-radius: 50%;
    background: var(--text-dim);
    transition: all 0.4s ease;
  }
  .diagram-node.is-on {
    opacity: 1;
    transform: translate(-50%, -50%) scale(1);
    color: var(--accent-2);
    border-color: rgba(var(--page-glow), 0.3);
    box-shadow: var(--nm-shadow-outset-sm), 0 0 18px rgba(var(--page-glow), 0.12);
  }
  .diagram-node.is-on .node-dot {
    background: var(--accent);
    box-shadow: 0 0 8px rgba(var(--page-glow), 0.9);
  }

  .loop-badge {
    position: absolute;
    left: 50%; bottom: -2.4rem;
    transform: translateX(-50%);
    font-size: 0.6rem; letter-spacing: 0.16em;
    color: var(--text-dim);
    white-space: nowrap;
    opacity: 0;
    transition: opacity 0.6s ease;
  }
  .stage-diagram[data-active="4"] .loop-badge { opacity: 0.8; }

  /* ── Copia ────────────────────────────────────────────────── */
  .stage-copy { position: relative; }
  .step-track { position: relative; min-height: 190px; }
  .stage-step {
    position: absolute; inset: 0;
    opacity: 0;
    transform: translateY(14px);
    transition: opacity 0.5s ease, transform 0.5s cubic-bezier(0.16, 1, 0.3, 1);
    pointer-events: none;
  }
  .stage-step.is-active { opacity: 1; transform: none; pointer-events: auto; }
  .step-no { font-size: 0.72rem; letter-spacing: 0.2em; color: var(--accent-2); }
  .step-title { font-size: clamp(1.5rem, 1.2rem + 1.6vw, 2.2rem); margin-top: 0.6rem; }
  .step-body { color: var(--text-soft); margin-top: 0.9rem; max-width: 46ch; font-size: 1.02rem; }

  .trace { margin-top: 1.6rem; padding: 1rem 1.1rem; }
  .trace-head {
    display: flex; align-items: center; gap: 0.5rem;
    font-size: 0.62rem; letter-spacing: 0.2em; text-transform: uppercase;
    color: var(--text-dim); margin-bottom: 0.7rem;
  }
  .trace-dot {
    width: 6px; height: 6px; border-radius: 50%;
    background: var(--accent);
    box-shadow: 0 0 8px rgba(var(--page-glow), 0.8);
    animation: pulse-glow 2s infinite ease-in-out;
  }
  .trace-log { display: grid; gap: 0.3rem; font-size: 0.74rem; min-height: 5.2em; }
  .trace-line { color: var(--text-soft); }
  .trace-line.is-new { color: var(--accent-2); animation: trace-in 0.45s ease both; }
  @keyframes trace-in { from { opacity: 0; transform: translateX(-6px); } to { opacity: 1; transform: none; } }

  .step-progress { display: flex; gap: 0.5rem; margin-top: 1.4rem; }
  .prog-tick {
    height: 3px; flex: 1; border-radius: 99px;
    background: var(--bg-soft);
    box-shadow: var(--nm-shadow-inset-sm);
    overflow: hidden; position: relative;
    transition: background 0.4s ease;
  }
  .prog-tick.is-on { background: linear-gradient(90deg, var(--accent), var(--accent-2)); box-shadow: 0 0 10px rgba(var(--page-glow), 0.25); }

  @media (min-width: 880px) {
    .stage-grid { grid-template-columns: 0.9fr 1.1fr; gap: 4rem; }
    .stage-diagram { width: min(40vw, 420px); }
    .step-track { min-height: 220px; }
  }

  /* Fallback sin movimiento: apilar todo, sin sticky */
  .anatomy.reduced .anatomy-scroll { height: auto; }
  .anatomy.reduced .anatomy-stage { position: static; height: auto; padding-block: 3rem; }
  .anatomy.reduced .step-track { min-height: 0; display: grid; gap: 2rem; }
  .anatomy.reduced .stage-step { position: static; opacity: 1; transform: none; }
  @media (prefers-reduced-motion: reduce) {
    .core-ring { animation: none; }
  }
</style>

---
import { community } from "../data/content";
import T from "./T.astro";
const base = import.meta.env.BASE_URL;
---

<section id="community" class="section" data-palette="sice">
  <div class="shell comm-grid">
    <div class="comm-copy">
      <p class="kicker reveal"><T es={community.kicker.es} en={community.kicker.en} /></p>
      <h2 class="section-title reveal" data-delay="1"><T es={community.title.es} en={community.title.en} /></h2>
      <p class="comm-org font-mono reveal" data-delay="1">
        {community.org} · <T es={community.date.es} en={community.date.en} />
      </p>
      <p class="section-lead reveal" data-delay="2"><T es={community.description.es} en={community.description.en} /></p>

      <div class="comm-topics-container nm-recessed reveal" data-delay="2">
        <span class="topics-label font-mono"><T es="Temas claves compartidos" en="Key topics shared" /></span>
        <ul class="comm-topics">
          {community.topics.map((t) => (
            <li><span class="hl-mark" aria-hidden="true">▹</span><T es={t.es} en={t.en} /></li>
          ))}
        </ul>
      </div>
    </div>

    <div class="comm-media reveal" data-delay="2">
      <div class="comm-frame">
        <img src={`${base}images/sice-keyart.png`} alt="SICE México — Masterclass" loading="lazy" width="520" height="520" />
      </div>
      <div class="comm-frame comm-frame--sm">
        <img src={`${base}images/sice-session.jpg`} alt="Sesión de la masterclass" loading="lazy" width="320" height="240" />
      </div>
      <div class="media-glow-effect" aria-hidden="true"></div>
    </div>
  </div>
</section>

<style>
  .comm-grid { display: grid; grid-template-columns: 1fr; gap: 3rem; align-items: center; }
  .comm-org { color: var(--accent-2); font-size: 0.76rem; margin-top: 1rem; letter-spacing: 0.04em; }
  
  .comm-topics-container {
    margin-top: 2rem;
    padding: 1.4rem;
  }
  .topics-label {
    display: block;
    font-size: 0.68rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--text-dim);
    margin-bottom: 0.8rem;
  }
  .comm-topics { list-style: none; display: grid; gap: 0.75rem; }
  .comm-topics li { display: grid; grid-template-columns: auto 1fr; gap: 0.7rem; color: var(--text-soft); font-size: 0.96rem; }
  .hl-mark { color: var(--accent); }

  .comm-media { position: relative; justify-self: center; max-width: 460px; width: 100%; }
  
  .comm-frame { 
    border-radius: 1.4rem; 
    overflow: hidden; 
    border: 1px solid rgba(255,255,255,0.015); 
    box-shadow: var(--nm-shadow-outset); 
    position: relative;
    z-index: 2;
  }
  .comm-frame img { display: block; width: 100%; height: auto; filter: saturate(0.98); }
  
  .comm-frame--sm { 
    position: absolute; 
    right: -14px; 
    bottom: -22px; 
    width: 42%; 
    border: 3px solid var(--bg); 
    box-shadow: var(--nm-shadow-outset-sm); 
    z-index: 3;
    border-radius: 0.8rem;
  }

  .media-glow-effect {
    position: absolute;
    inset: 20px;
    background: rgba(var(--page-glow), 0.12);
    filter: blur(35px);
    z-index: 1;
    pointer-events: none;
  }

  @media (min-width: 920px) {
    .comm-grid { grid-template-columns: 1.1fr 0.9fr; gap: 4.5rem; }
    .comm-media { justify-self: end; }
  }
</style>

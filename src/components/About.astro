---
import { about, profile } from "../data/content";
import { ui } from "../data/ui";
import T from "./T.astro";
const base = import.meta.env.BASE_URL;
---

<section id="about" class="section" data-palette="iris">
  <div class="shell about-grid">
    <div class="about-content">
      <div class="about-head">
        <p class="kicker reveal"><T es={ui.about_kicker.es} en={ui.about_kicker.en} /></p>
        <h2 class="section-title reveal" data-delay="1">
          <T es={ui.about_title.es} en={ui.about_title.en} />
        </h2>
      </div>

      <div class="about-body">
        {about.paragraphs.map((p, i) => (
          <p class="about-p reveal" data-delay={i}>
            <T es={p.es} en={p.en} />
          </p>
        ))}
      </div>

      <div class="about-facts">
        {about.facts.map((f, i) => (
          <div class="fact card reveal" data-delay={i}>
            <span class="metric">{f.value}</span>
            <span class="fact-label font-mono"><T es={f.label.es} en={f.label.en} /></span>
          </div>
        ))}
      </div>
    </div>

    <div class="about-portrait reveal" data-delay="2">
      <div class="portrait-frame">
        <img
          src={`${base}images/diego-portrait.jpg`}
          alt={profile.name}
          width="430"
          height="560"
          loading="lazy"
        />
        <div class="portrait-glow" aria-hidden="true"></div>
      </div>
      <div class="portrait-badge font-mono">
        <span class="dot"></span>
        <T es="Hablemos de IA" en="Let's talk AI" />
      </div>
    </div>
  </div>
</section>

<style>
  .about-grid { display: grid; grid-template-columns: 1fr; gap: 3rem; align-items: center; }
  .about-content { display: flex; flex-direction: column; }
  .about-body { display: grid; gap: 1.3rem; max-width: 64ch; margin-top: 1.6rem; }
  .about-p { color: var(--text-soft); font-size: clamp(1.02rem, 0.98rem + 0.3vw, 1.15rem); }
  .about-p :global(br) { display: block; content: ""; margin-top: 0.4rem; }

  .about-facts {
    display: grid; grid-template-columns: repeat(2, 1fr); gap: 1.2rem;
    margin-top: 2rem;
  }
  .fact { 
    display: flex; flex-direction: column; gap: 0.4rem; padding: 1.4rem 1.2rem; 
    align-items: center; text-align: center;
  }
  .fact-label { font-size: 0.72rem; color: var(--text-dim); letter-spacing: 0.02em; max-width: 22ch; }

  .about-portrait { position: relative; justify-self: center; max-width: 320px; width: 100%; margin-top: 2.2rem; }
  .portrait-frame {
    position: relative; border-radius: 1.4rem; overflow: hidden;
    background: var(--bg);
    border: 1px solid rgba(255, 255, 255, 0.015);
    box-shadow: var(--nm-shadow-outset);
  }
  .portrait-frame img { display: block; width: 100%; height: auto; filter: saturate(0.95) contrast(1.02); }
  .portrait-glow {
    position: absolute; inset: 0;
    background: linear-gradient(180deg, transparent 60%, rgba(15,17,26,0.6));
    mix-blend-mode: multiply;
  }
  .portrait-badge {
    position: absolute; left: 50%; bottom: -18px; transform: translateX(-50%);
    display: inline-flex; align-items: center; gap: 0.5rem; white-space: nowrap;
    padding: 0.5rem 0.95rem; border-radius: 99px; font-size: 0.72rem;
    background: rgba(15,17,26,0.85); border: 1px solid var(--border-strong);
    backdrop-filter: blur(8px); color: var(--text-soft);
    box-shadow: var(--nm-shadow-outset-sm);
  }
  .dot { width: 8px; height: 8px; border-radius: 99px; background: #2fcf6b; box-shadow: 0 0 0 4px rgba(47,207,107,0.15); }

  @media (min-width: 900px) {
    .about-grid { grid-template-columns: 1.15fr 0.85fr; gap: 4.5rem; }
    .about-portrait { justify-self: end; margin-top: 0; }
  }
</style>

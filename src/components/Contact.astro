---
import { profile } from "../data/content";
import { ui } from "../data/ui";
import T from "./T.astro";
const year = new Date().getFullYear();
---

<section id="contact" class="section" data-palette="iris">
  <div class="shell">
    <div class="contact-card card reveal">
      <p class="kicker"><T es={ui.contact_kicker.es} en={ui.contact_kicker.en} /></p>
      <h2 class="contact-title"><T es={ui.contact_title.es} en={ui.contact_title.en} /></h2>
      <p class="section-lead" style="margin-inline:auto;"><T es={ui.contact_lead.es} en={ui.contact_lead.en} /></p>

      <a class="contact-mail font-display" href={`mailto:${profile.email}`}>{profile.email}</a>

      <div class="contact-links">
        <a class="btn btn-primary" href={`mailto:${profile.email}`}>
          <T es={ui.email_label.es} en={ui.email_label.en} /> <span aria-hidden="true">→</span>
        </a>
        <a class="btn" href={profile.links.linkedin} target="_blank" rel="noopener">LinkedIn</a>
        <a class="btn" href={profile.links.github} target="_blank" rel="noopener">GitHub</a>
        <a class="btn" href={profile.links.instagram} target="_blank" rel="noopener">Instagram</a>
      </div>
    </div>
  </div>

  <footer class="footer">
    <div class="shell footer-inner">
      <span class="font-mono">© {year} {profile.name}</span>
      <span class="font-mono footer-credit"><T es={ui.rights.es} en={ui.rights.en} /> · Astro</span>
    </div>
  </footer>
</section>

<style>
  .contact-card { 
    text-align: center; 
    max-width: 860px; 
    margin-inline: auto; 
    padding: clamp(2.5rem, 2rem + 4vw, 5rem) clamp(1.2rem, 1rem + 2.5vw, 3.5rem);
    display: flex;
    flex-direction: column;
    align-items: center;
  }
  
  .contact-title { font-size: clamp(2rem, 1.4rem + 3.2vw, 3.6rem); margin-top: 1.1rem; line-height: 1.15; max-width: 20ch; }
  
  .contact-mail {
    display: inline-block; 
    margin-top: 2.2rem; 
    font-size: clamp(1.25rem, 0.9rem + 2vw, 2.2rem);
    color: var(--accent-2); 
    border-bottom: 1px dashed transparent; 
    transition: all 0.35s cubic-bezier(0.16, 1, 0.3, 1);
  }
  .contact-mail:hover { color: var(--text); border-color: var(--accent); transform: scale(1.01); }
  
  .contact-links { display: flex; flex-wrap: wrap; gap: 1rem; justify-content: center; margin-top: 2.6rem; }

  .footer { margin-top: clamp(4rem, 3rem + 6vw, 7rem); border-top: 1px solid var(--border); padding-top: 2rem; }
  .footer-inner { display: flex; flex-wrap: wrap; gap: 0.6rem 1.5rem; justify-content: space-between; font-size: 0.76rem; color: var(--text-dim); }
</style>

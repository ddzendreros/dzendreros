---
/* ════════════════════════════════════════════════════════════════════════
   NeuralField — grafo de razonamiento ambiental (canvas)
   No es un campo de partículas genérico: es un grafo disperso de nodos con
   "señales" que viajan por las aristas, como el flujo de estados de un agente.
   Adopta el acento de la sección visible, reacciona sutil al cursor, se pausa
   fuera de pantalla y respeta prefers-reduced-motion.
   ════════════════════════════════════════════════════════════════════════ */
---

<canvas class="neural-field" aria-hidden="true"></canvas>

<script is:inline>
  (function () {
    const canvas = document.querySelector(".neural-field");
    if (!canvas) return;
    const reduce = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
    const ctx = canvas.getContext("2d", { alpha: true });
    if (!ctx) return;

    const root = document.documentElement;
    let W = 0, H = 0, DPR = 1;
    let nodes = [];
    let signals = [];
    let glow = [212, 168, 75];
    let raf = null;
    let visible = true;
    let frame = 0;
    const mouse = { x: -9999, y: -9999, active: false };

    function readGlow() {
      const v = getComputedStyle(root).getPropertyValue("--page-glow").trim();
      const parts = v.split(",").map((n) => parseInt(n.trim(), 10));
      if (parts.length === 3 && parts.every((n) => !isNaN(n))) glow = parts;
    }

    function size() {
      const rect = canvas.getBoundingClientRect();
      DPR = Math.min(window.devicePixelRatio || 1, 2);
      W = rect.width;
      H = rect.height;
      canvas.width = Math.round(W * DPR);
      canvas.height = Math.round(H * DPR);
      ctx.setTransform(DPR, 0, 0, DPR, 0, 0);
      build();
    }

    function build() {
      // Densidad proporcional al área, acotada para rendimiento.
      const target = Math.round(Math.min(58, Math.max(22, (W * H) / 22000)));
      nodes = [];
      for (let i = 0; i < target; i++) {
        nodes.push({
          x: Math.random() * W,
          y: Math.random() * H,
          vx: (Math.random() - 0.5) * 0.16,
          vy: (Math.random() - 0.5) * 0.16,
          r: Math.random() * 1.4 + 0.7,
          pulse: Math.random() * Math.PI * 2,
        });
      }
      signals = [];
    }

    const LINK = 132; // distancia máxima de arista

    function spawnSignal() {
      if (nodes.length < 2 || signals.length > 5) return;
      const a = (Math.random() * nodes.length) | 0;
      // elige un vecino cercano
      let best = -1, bestD = LINK * LINK;
      for (let j = 0; j < nodes.length; j++) {
        if (j === a) continue;
        const dx = nodes[a].x - nodes[j].x;
        const dy = nodes[a].y - nodes[j].y;
        const d = dx * dx + dy * dy;
        if (d < bestD && Math.random() > 0.5) { bestD = d; best = j; }
      }
      if (best === -1) return;
      signals.push({ a, b: best, t: 0, speed: 0.012 + Math.random() * 0.02 });
    }

    function step() {
      frame++;
      if (frame % 40 === 0) readGlow();
      ctx.clearRect(0, 0, W, H);

      // mover nodos
      for (const n of nodes) {
        n.x += n.vx;
        n.y += n.vy;
        if (n.x < -20) n.x = W + 20; else if (n.x > W + 20) n.x = -20;
        if (n.y < -20) n.y = H + 20; else if (n.y > H + 20) n.y = -20;

        // atracción suave hacia el cursor (parallax de campo)
        if (mouse.active) {
          const dx = mouse.x - n.x;
          const dy = mouse.y - n.y;
          const d2 = dx * dx + dy * dy;
          if (d2 < 26000) {
            const f = (1 - d2 / 26000) * 0.5;
            n.x += (dx / Math.sqrt(d2 + 1)) * f;
            n.y += (dy / Math.sqrt(d2 + 1)) * f;
          }
        }
      }

      // aristas
      const g = glow;
      for (let i = 0; i < nodes.length; i++) {
        for (let j = i + 1; j < nodes.length; j++) {
          const dx = nodes[i].x - nodes[j].x;
          const dy = nodes[i].y - nodes[j].y;
          const d = Math.sqrt(dx * dx + dy * dy);
          if (d < LINK) {
            const o = (1 - d / LINK) * 0.22;
            ctx.strokeStyle = `rgba(${g[0]},${g[1]},${g[2]},${o})`;
            ctx.lineWidth = 0.6;
            ctx.beginPath();
            ctx.moveTo(nodes[i].x, nodes[i].y);
            ctx.lineTo(nodes[j].x, nodes[j].y);
            ctx.stroke();
          }
        }
      }

      // nodos
      for (const n of nodes) {
        n.pulse += 0.03;
        const a = 0.45 + Math.sin(n.pulse) * 0.2;
        ctx.fillStyle = `rgba(${g[0]},${g[1]},${g[2]},${a})`;
        ctx.beginPath();
        ctx.arc(n.x, n.y, n.r, 0, Math.PI * 2);
        ctx.fill();
      }

      // señales viajando por aristas
      if (Math.random() < 0.04) spawnSignal();
      for (let s = signals.length - 1; s >= 0; s--) {
        const sig = signals[s];
        sig.t += sig.speed;
        if (sig.t >= 1) { signals.splice(s, 1); continue; }
        const na = nodes[sig.a], nb = nodes[sig.b];
        if (!na || !nb) { signals.splice(s, 1); continue; }
        const x = na.x + (nb.x - na.x) * sig.t;
        const y = na.y + (nb.y - na.y) * sig.t;
        const fade = Math.sin(sig.t * Math.PI);
        ctx.fillStyle = `rgba(${g[0]},${g[1]},${g[2]},${0.9 * fade})`;
        ctx.beginPath();
        ctx.arc(x, y, 1.8, 0, Math.PI * 2);
        ctx.fill();
        ctx.fillStyle = `rgba(${g[0]},${g[1]},${g[2]},${0.18 * fade})`;
        ctx.beginPath();
        ctx.arc(x, y, 5, 0, Math.PI * 2);
        ctx.fill();
      }

      raf = requestAnimationFrame(step);
    }

    function start() {
      if (raf || reduce) return;
      raf = requestAnimationFrame(step);
    }
    function stop() {
      if (raf) cancelAnimationFrame(raf);
      raf = null;
    }

    // estado estático accesible si reduce-motion
    function drawStatic() {
      readGlow();
      ctx.clearRect(0, 0, W, H);
      const g = glow;
      for (let i = 0; i < nodes.length; i++) {
        for (let j = i + 1; j < nodes.length; j++) {
          const dx = nodes[i].x - nodes[j].x;
          const dy = nodes[i].y - nodes[j].y;
          const d = Math.sqrt(dx * dx + dy * dy);
          if (d < LINK) {
            ctx.strokeStyle = `rgba(${g[0]},${g[1]},${g[2]},${(1 - d / LINK) * 0.18})`;
            ctx.lineWidth = 0.6;
            ctx.beginPath();
            ctx.moveTo(nodes[i].x, nodes[i].y);
            ctx.lineTo(nodes[j].x, nodes[j].y);
            ctx.stroke();
          }
        }
      }
      for (const n of nodes) {
        ctx.fillStyle = `rgba(${g[0]},${g[1]},${g[2]},0.5)`;
        ctx.beginPath();
        ctx.arc(n.x, n.y, n.r, 0, Math.PI * 2);
        ctx.fill();
      }
    }

    // Cursor (relativo al canvas)
    const host = canvas.parentElement || canvas;
    host.addEventListener("pointermove", (e) => {
      const rect = canvas.getBoundingClientRect();
      mouse.x = e.clientX - rect.left;
      mouse.y = e.clientY - rect.top;
      mouse.active = true;
    });
    host.addEventListener("pointerleave", () => { mouse.active = false; mouse.x = -9999; mouse.y = -9999; });

    // Pausa fuera de pantalla
    const io = new IntersectionObserver((entries) => {
      visible = entries[0].isIntersecting;
      if (visible && !document.hidden) start(); else stop();
    }, { threshold: 0.01 });
    io.observe(canvas);

    document.addEventListener("visibilitychange", () => {
      if (document.hidden) stop(); else if (visible) start();
    });

    let rt;
    window.addEventListener("resize", () => {
      clearTimeout(rt);
      rt = setTimeout(() => { size(); if (reduce) drawStatic(); }, 180);
    });

    size();
    if (reduce) drawStatic(); else start();
  })();
</script>

<style>
  .neural-field {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    z-index: 0;
    pointer-events: none;
    opacity: 0.62;
    -webkit-mask-image: radial-gradient(95% 90% at 72% 42%, #000 45%, transparent 100%);
    mask-image: radial-gradient(95% 90% at 72% 42%, #000 45%, transparent 100%);
  }
</style>

---
import { achievements } from "../data/content";
import { ui } from "../data/ui";
import T from "./T.astro";
const base = import.meta.env.BASE_URL;
---

<section id="achievements" class="section" data-palette="talent">
  <div class="shell">
    <div class="ach-head">
      <p class="kicker reveal"><T es={ui.achievements_kicker.es} en={ui.achievements_kicker.en} /></p>
      <h2 class="section-title reveal" data-delay="1"><T es={ui.achievements_title.es} en={ui.achievements_title.en} /></h2>
      <p class="section-lead reveal" data-delay="2"><T es={ui.achievements_lead.es} en={ui.achievements_lead.en} /></p>
    </div>

    <div class="ach-list">
      {achievements.map((a) => (
        <article class="ach card reveal" data-palette={a.palette}>
          <div class={`ach-gallery ${a.images.length === 1 ? "is-single" : ""}`}>
            {a.images.map((img, i) => (
              <img
                class={`ach-img ${i === 0 ? "is-main" : ""}`}
                src={`${base}images/${img.src}`}
                alt={img.alt.es}
                loading="lazy"
                width="600" height="400"
              />
            ))}
          </div>

          <div class="ach-body">
            <div class="ach-award">
              <span class="chip award-badge">🏆 <T es={a.award.es} en={a.award.en} /></span>
            </div>
            <h3 class="ach-name">{a.name}</h3>
            <p class="ach-subtitle"><T es={a.subtitle.es} en={a.subtitle.en} /></p>
            <p class="ach-org font-mono">
              <T es={a.org.es} en={a.org.en} /> · <T es={a.date.es} en={a.date.en} />
            </p>

            <p class="ach-desc"><T es={a.description.es} en={a.description.en} /></p>

            <div class="ach-role nm-recessed">
              <span class="proj-label font-mono"><T es={ui.role_label.es} en={ui.role_label.en} /></span>
              <p><T es={a.role.es} en={a.role.en} /></p>
            </div>

            <div class="chips">
              {a.tags.map((t) => <span class="chip">{t}</span>)}
            </div>

            {a.repo && (
              <a class="btn btn-ghost ach-repo" href={a.repo} target="_blank" rel="noopener">
                <svg viewBox="0 0 16 16" width="15" height="15" fill="currentColor" aria-hidden="true">
                  <path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.01 8.01 0 0016 8c0-4.42-3.58-8-8-8z"/>
                </svg>
                <T es="Ver repositorio" en="View repository" />
                <span aria-hidden="true">→</span>
              </a>
            )}
          </div>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .ach-head { max-width: 58ch; margin-bottom: 3.2rem; }
  .ach-list { display: grid; gap: 3rem; }
  .ach { display: grid; grid-template-columns: 1fr; overflow: hidden; }

  .ach-gallery { display: grid; grid-template-columns: 2fr 1fr; grid-template-rows: 1fr 1fr; gap: 6px; min-height: 250px; background: var(--bg-soft); }
  .ach-img { width: 100%; height: 100%; object-fit: cover; filter: saturate(0.9) brightness(0.88); transition: all 0.4s ease; }
  .ach-img.is-main { grid-row: 1 / span 2; }
  .ach:hover .ach-img { filter: saturate(1.02) brightness(1); transform: scale(1.01); }

  /* Galería de una sola imagen (p. ej. un certificado en vertical) */
  .ach-gallery.is-single {
    display: flex; align-items: center; justify-content: center;
    padding: clamp(1.4rem, 1rem + 2vw, 2.6rem);
    background: radial-gradient(120% 90% at 50% 22%, rgba(var(--glow), 0.14), var(--bg-soft));
  }
  .ach-gallery.is-single .ach-img {
    width: auto; height: auto; max-width: 100%; max-height: 470px;
    object-fit: contain; filter: none;
    border-radius: 0.7rem;
    box-shadow: var(--nm-shadow-outset);
  }
  .ach:hover .ach-gallery.is-single .ach-img { filter: none; transform: translateY(-3px) scale(1.01); }

  .ach-repo { margin-top: 1.5rem; align-self: flex-start; }

  .ach-body { padding: clamp(1.6rem, 1.2rem + 1.8vw, 3rem); display: flex; flex-direction: column; gap: 0.6rem; }
  .ach-award { margin-bottom: 0.4rem; }
  
  .award-badge {
    box-shadow: var(--nm-shadow-inset-sm);
    color: var(--accent-2);
    font-weight: 500;
  }

  .ach-name { font-size: clamp(1.6rem, 1.3rem + 1.4vw, 2.3rem); }
  .ach-subtitle { color: var(--text-soft); font-size: 1.02rem; }
  .ach-org { font-size: 0.74rem; color: var(--accent-2); letter-spacing: 0.02em; margin-top: 0.2rem; }
  .ach-desc { color: var(--text-soft); margin-top: 0.8rem; font-size: 0.98rem; }
  
  .ach-role { 
    margin-top: 1.2rem; 
    padding: 1.2rem; 
    border-radius: 1rem;
    box-shadow: var(--nm-shadow-inset-sm); 
  }
  .ach-role p { color: var(--text-soft); font-size: 0.94rem; }
  
  .ach-body .chips { margin-top: 1.2rem; display: flex; flex-wrap: wrap; gap: 0.5rem; }
  .proj-label { display: block; font-size: 0.7rem; letter-spacing: 0.18em; text-transform: uppercase; color: var(--text-dim); margin-bottom: 0.5rem; }

  @media (min-width: 900px) {
    .ach { grid-template-columns: 0.95fr 1.05fr; }
    .ach-gallery { min-height: 100%; }
  }
</style>

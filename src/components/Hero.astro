---
import { profile } from "../data/content";
import { ui } from "../data/ui";
import T from "./T.astro";
import Terminal from "./Terminal.astro";
import NeuralField from "./NeuralField.astro";
const base = import.meta.env.BASE_URL;
---

<section id="home" class="hero section" data-palette="iris">
  <NeuralField />
  <div class="shell hero-grid">
    <div class="hero-copy">
      <p class="kicker reveal">
        <T es={profile.role.es} en={profile.role.en} />
      </p>

      <h1 class="hero-title reveal" data-delay="1" data-decode>
        <T es={profile.headline.es} en={profile.headline.en} />
      </h1>

      <p class="hero-intro section-lead reveal" data-delay="2">
        <T es={profile.intro.es} en={profile.intro.en} />
      </p>

      <div class="hero-actions reveal" data-delay="3">
        <a class="btn btn-primary" href="#projects">
          <T es={ui.cta_projects.es} en={ui.cta_projects.en} />
          <span aria-hidden="true">→</span>
        </a>
        <a class="btn btn-ghost" href={`mailto:${profile.email}`}>
          <T es={ui.cta_contact.es} en={ui.cta_contact.en} />
        </a>
      </div>

      <div class="hero-meta reveal" data-delay="3">
        <span class="font-mono">📍 <T es={profile.location.es} en={profile.location.en} /></span>
        <a class="font-mono link-underline" href={`mailto:${profile.email}`}>{profile.email}</a>
      </div>
    </div>

    <div class="hero-terminal-container reveal" data-delay="2">
      <Terminal />
      <div class="terminal-shadow-glow" aria-hidden="true"></div>
    </div>
  </div>

  <div class="scroll-hint font-mono" aria-hidden="true">
    <T es={ui.scroll.es} en={ui.scroll.en} /><span class="scroll-line"></span>
  </div>
</section>

<style>
  .hero { min-height: 100vh; display: flex; align-items: center; padding-top: 88px; position: relative; overflow: hidden; }
  .hero-grid {
    display: grid; grid-template-columns: 1fr; gap: 3rem; align-items: center;
    position: relative; z-index: 2;
  }
  .hero-title {
    font-size: clamp(2.4rem, 1.4rem + 5vw, 4.8rem);
    margin-top: 1.2rem; line-height: 1.05;
    font-weight: 500;
    /* Barrido morado → azul → verde: la paleta de marca en el titular */
    background: linear-gradient(115deg, #f5f2ec 0%, #c4b8ff 36%, #84b6ff 68%, #6fe0ad 100%);
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
  }
  .hero-intro { margin-top: 1.4rem; max-width: 52ch; }
  .hero-actions { display: flex; flex-wrap: wrap; gap: 1rem; margin-top: 2rem; }
  .hero-meta { display: flex; flex-wrap: wrap; gap: 1.4rem; margin-top: 2.2rem; font-size: 0.85rem; color: var(--text-dim); }

  .hero-terminal-container { 
    position: relative; 
    justify-self: center; 
    width: 100%; 
    max-width: 580px; 
  }
  .terminal-shadow-glow {
    position: absolute;
    inset: 15px;
    background: rgba(var(--page-glow), 0.15);
    filter: blur(40px);
    z-index: -1;
    pointer-events: none;
    border-radius: 1.1rem;
    transition: background 1.2s ease;
  }

  .scroll-hint {
    position: absolute;
    left: 50%;
    bottom: 1.5rem;
    transform: translateX(-50%);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.6rem;
    font-size: 0.65rem;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: var(--text-dim);
    user-select: none;
    z-index: 2;
  }
  .scroll-line { 
    width: 1px; 
    height: 34px; 
    background: linear-gradient(var(--accent), transparent);
    animation: scroll-bounce 2s infinite ease-in-out;
  }

  @keyframes scroll-bounce {
    0%, 100% { transform: translateY(0); opacity: 0.3; }
    50% { transform: translateY(6px); opacity: 1; }
  }

  @media (min-width: 960px) {
    .hero-grid { grid-template-columns: 1.15fr 0.85fr; gap: 3.5rem; }
    .hero-terminal-container { justify-self: end; }
  }
</style>
